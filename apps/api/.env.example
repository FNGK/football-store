ENVIRONMENT=development
DEBUG=true

DATABASE_URL=postgresql+asyncpg://amp:amp@localhost:5432/amp

# Required — generate: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=REPLACE_WITH_SECRET_MIN_32_CHARS________________________

ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

CORS_ORIGINS=http://localhost:3000
ALLOWED_HOSTS=localhost,127.0.0.1

RATE_LIMIT_PER_MINUTE=120

# First-run admin (change before production deploy)
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=ChangeMeNow123!
BOOTSTRAP_TENANT_NAME=Default Organization

PII_FERNET_KEY=

OPENAI_API_KEY=
AGENTS_ENABLED=true

AWS_REGION=us-east-1
AWS_PROFILE=default
BIGQUERY_PROJECT_ID=
BIGQUERY_DATASET=

SENTRY_DSN=
